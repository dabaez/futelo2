DOMAIN=your-domain.com
BOT_TOKEN=your_telegram_bot_token_here
MINI_APP_URL=https://your-domain.com
# Direct Mini App link from BotFather (set this to get proper initData in groups)
# Format: https://t.me/your_bot_username/your_app_name
# Without this, the /start button in groups opens a plain URL with no Telegram context.
MINI_APP_DIRECT_LINK=https://t.me/your_bot_username/your_app_name
SERVER_PORT=3001
# Secret used to validate Telegram WebApp initData
BOT_TOKEN_HASH=
# Optional: set to "webhook" in production, "polling" in dev
BOT_MODE=polling
WEBHOOK_DOMAIN=https://your-domain.com

# ── Dev / local testing ────────────────────────────────────────────────────
# Set to "true" to skip Telegram initData validation entirely.
# Accepts dev initData of the form:  dev:USER_ID:username:First Name
# NEVER set to true in production.
DEV_MODE=false
